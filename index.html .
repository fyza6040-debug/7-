body {
  font-family: Arial;
  background: linear-gradient(135deg, #6a5acd, #20b2aa);
  text-align: center;
  color: white;
}

.container {
  margin-top: 100px;
}

.box {
  background: rgba(0,0,0,0.3);
  padding: 20px;
  display: inline-block;
  border-radius: 15px;
}

input {
  display: block;
  margin: 10px;
  padding: 10px;
  width: 200px;
}

button {
  padding: 10px 20px;
  background: white;
  border: none;
  cursor: pointer;
}
