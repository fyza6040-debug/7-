<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>كنترول كب كيك VIP🤭</title>

<style>
body{
  font-family:Arial;
  text-align:center;
  direction:rtl;
  background:#111;
  color:white;
}

.card{
  margin-top:120px;
}

button{
  padding:15px 25px;
  margin:10px;
  border:none;
  border-radius:10px;
  cursor:pointer;
  font-size:16px;
}

.open{
  background:#2ecc71;
  color:white;
}

.close{
  background:#e74c3c;
  color:white;
}

h1{
  color:#ffcc70;
}
</style>
</head>

<body>

<div class="card">
  <h1>🎮 كنترول كب كيك VIP🤭</h1>

  <button class="open" onclick="openGame()">فتح اللعبة</button>
  <button class="close" onclick="closeGame()">إغلاق اللعبة</button>

  <p id="status"></p>
</div>

<script>
function openGame(){
  localStorage.setItem("gameStatus","open");
  document.getElementById("status").innerText = "✅ اللعبة مفتوحة";
}

function closeGame(){
  localStorage.setItem("gameStatus","closed");
  document.getElementById("status").innerText = "🔒 اللعبة مقفولة";
}

let status = localStorage.getItem("gameStatus");

if(status === "open"){
  document.getElementById("status").innerText = "✅ اللعبة مفتوحة";
}else{
  document.getElementById("status").innerText = "🔒 اللعبة مقفولة";
}
</script>

</body>
</html>
